{
  "manifest_version": 3,
  "name": "Swipe2Home",
  "version": "1.0.2",
  "description": "Keka ClockOut Calculator - Calculate your exact leave time using punch logs and breaks.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://*.keka.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Swipe2Home",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.keka.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}